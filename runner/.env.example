# Copy to runner/.env (gitignored) and fill in local-only overrides.
#
# The runner harness will:
# - load runner/.env (if present)
# - apply default values for missing SHISAD_* settings
#
# Do NOT commit API keys or other secrets.

# --- tmux (background daemon persistence) ---
# RUNNER_TMUX_SOCKET_NAME=shisad-runner
# RUNNER_TMUX_SESSION_NAME=shisad-m5

# --- Daemon paths (defaults are usually fine) ---
# SHISAD_DATA_DIR=/path/to/shisad/.local/shisad-m5
# SHISAD_SOCKET_PATH=/tmp/shisad-m5.sock
# SHISAD_POLICY_PATH=/path/to/shisad/.local/policy.yaml

# --- Coding repo ---
# SHISAD_CODING_REPO_ROOT=/path/to/shisad

# --- Planner route ---
# SHISAD_MODEL_PLANNER_PROVIDER_PRESET=shisa_default
# SHISAD_MODEL_PLANNER_MODEL_ID=shisa-ai/shisa-v2.1-unphi4-14b
# SHISAD_MODEL_PLANNER_REMOTE_ENABLED=true
# SHISAD_MODEL_ENFORCE_SECURITY_ROUTE_PINNING=false

# --- Credentials (set exactly one; do not commit) ---
# OPENAI_API_KEY=...
# SHISA_API_KEY=...
# OPENROUTER_API_KEY=...
# GEMINI_API_KEY=...
